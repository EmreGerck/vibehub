generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "rhel-openssl-3.0.x", "linux-musl", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  CUSTOMER
  VENDOR_OWNER
  VENDOR_MANAGER
  PLATFORM_ADMIN
  GOD_USER
}

enum ArtistType {
  BAND
  COMEDIAN
  INFLUENCER
  ARTIST
  OTHER
}

enum TenantStatus {
  PENDING
  ACTIVE
  FROZEN
  REJECTED
}

enum ProductStatus {
  DRAFT
  PENDING_REVIEW
  LIVE
  ARCHIVED
}

enum OrderStatus {
  PLACED
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum ShipmentStatus {
  CREATED
  IN_TRANSIT
  DELIVERED
  FAILED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

enum VendorPermission {
  PRODUCT_CREATE
  PRODUCT_EDIT
  PRODUCT_DELETE
  PRODUCT_SUBMIT
  PRODUCT_PUBLISH_DIRECT
  VARIANT_MANAGE
  INVENTORY_EDIT
  ORDER_VIEW
  ORDER_FULFILL
  STOREFRONT_EDIT
  PAYOUT_REQUEST
  ANALYTICS_VIEW
  MANAGER_INVITE
  FORUM_MANAGE
  MEDIA_MANAGE
}

enum MediaType {
  SPOTIFY
  YOUTUBE
}

enum ReactionEmoji {
  FIRE
  HEART
  CLAP
  EYES
  HUNDRED
  ROCKET
}

enum EventProvider {
  BILETINO
  BILETIX
  BILETINIAL
  OTHER
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String?
  phone        String?
  avatarUrl    String?
  role         UserRole @default(CUSTOMER)
  tenantId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  // Legal consent tracking (KVKK)
  termsAcceptedAt    DateTime?
  privacyAcceptedAt  DateTime?
  marketingConsent   Boolean   @default(false)
  marketingConsentAt DateTime?
  kvkkAcceptedAt     DateTime?
  accountDeletedAt   DateTime?
  lockedUntil        DateTime?

  tenant        Tenant?    @relation(fields: [tenantId], references: [id])
  orders        Order[]
  reviews       Review[]
  follows       Follow[]
  wishlist      Wishlist[]
  auditLogsAs   AuditLog[] @relation("ActorLogs")
  refreshTokens      RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  trustedDevices     TrustedDevice[]
  forumTopics        ForumTopic[]
  forumReplies       ForumReply[]
  forumReactions     ForumReaction[]
  socialProfile      UserProfile?
  profileVisitsMade  ProfileVisit[] @relation("VisitsMade")
  profileVisitsReceived ProfileVisit[] @relation("VisitsReceived")
  messagesSent       DirectMessage[] @relation("MessagesSent")
  messagesReceived   DirectMessage[] @relation("MessagesReceived")
  pushDevices        PushDevice[]
  notifications      AppNotification[]

  @@index([email])
  @@index([tenantId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model TrustedDevice {
  id         String   @id @default(uuid())
  token      String   @unique
  userId     String
  deviceName String?
  userAgent  String?
  lastUsedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model UserProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  nickname  String   @unique
  bio       String?
  interests String[]
  avatarUrl String?
  bannerUrl String?
  ghostMode Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([nickname])
}

model ProfileVisit {
  id            String   @id @default(uuid())
  visitorId     String
  profileUserId String
  createdAt     DateTime @default(now())

  visitor User @relation("VisitsMade", fields: [visitorId], references: [id], onDelete: Cascade)
  profile User @relation("VisitsReceived", fields: [profileUserId], references: [id], onDelete: Cascade)

  @@index([profileUserId, createdAt])
  @@index([visitorId])
}

model DirectMessage {
  id          String    @id @default(uuid())
  senderId    String
  recipientId String
  body        String
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  sender    User @relation("MessagesSent", fields: [senderId], references: [id], onDelete: Cascade)
  recipient User @relation("MessagesReceived", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([senderId, recipientId, createdAt])
  @@index([recipientId, createdAt])
}

model Tenant {
  id             String       @id @default(uuid())
  slug           String       @unique
  displayName    String
  artistType     ArtistType   @default(OTHER)
  status         TenantStatus @default(PENDING)
  commissionRate Decimal      @default(0.10) @db.Decimal(5, 4)
  bio            String?
  logoUrl        String?
  bannerUrl      String?
  brandColor     String?          // hex e.g. "#7c3aed"
  // ── Feature toggles (god-user controlled from admin panel) ────────────────
  forumEnabled   Boolean      @default(true)
  mediaEnabled   Boolean      @default(true)
  eventsEnabled  Boolean      @default(true)
  nfcEnabled     Boolean      @default(true)
  createdAt      DateTime     @default(now())

  users         User[]
  products      Product[]
  orderItems    OrderItem[]
  shipments     Shipment[]
  payouts       Payout[]
  followers     Follow[]
  heroBanners   HeroBanner[]
  permissions   TenantPermission[]
  forumSettings  ForumSettings?
  forumChannels  ForumChannel[]
  forumTopics    ForumTopic[]
  media         VendorMedia[]
  events        VendorEvent[]
  nfcTags       NfcTag[]

  @@index([slug])
  @@index([status])
}

model TenantPermission {
  id         String           @id @default(uuid())
  tenantId   String
  permission VendorPermission
  grantedBy  String
  grantedAt  DateTime         @default(now())
  note       String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, permission])
  @@index([tenantId])
}

model HeroBanner {
  id             String   @id @default(uuid())
  tenantId       String?
  title          String
  subtitle       String
  heading        String
  description    String
  buttonText     String
  buttonLink     String
  imageUrl       String?
  gradient       String   @default("linear-gradient(135deg, #070A12 0%, #0B1022 45%, #070A12 100%)")
  buttonGradient String   @default("linear-gradient(135deg, #7C3AED 0%, #EC4899 55%, #F97316 100%)")
  sortOrder      Int      @default(0)
  active         Boolean  @default(true)
  translations   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenant         Tenant?  @relation(fields: [tenantId], references: [id])
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  nameEn    String?
  slug      String    @unique
  icon      String?
  sortOrder Int       @default(0)
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  products  Product[]

  @@index([slug])
  @@index([sortOrder])
}

model Product {
  id           String        @id @default(uuid())
  tenantId     String
  categoryId   String?
  title        String
  description  String
  price        Decimal       @db.Decimal(12, 2)
  currency     String        @default("USD")
  status       ProductStatus @default(DRAFT)
  images          String[]
  tags            String[]
  translations    Json?
  previewVideoUrl String?
  shippingNote    String?          // e.g. "Ships in 3–5 business days via DHL"
  imageSettings   Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  category Category?        @relation(fields: [categoryId], references: [id])
  variants ProductVariant[]
  reviews  Review[]
  wishlist Wishlist[]

  @@index([tenantId])
  @@index([status])
  @@index([tags])
  @@index([categoryId])
}

model ProductVariant {
  id               String   @id @default(uuid())
  productId        String
  sku              String   @unique
  attributes       Json
  priceOverride    Decimal? @db.Decimal(12, 2)
  stockQty         Int      @default(0)
  lowStockThreshold Int     @default(5)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([productId])
  @@index([sku])
}

model Order {
  id              String      @id @default(uuid())
  customerId      String
  status          OrderStatus @default(PLACED)
  totalAmount     Decimal     @db.Decimal(12, 2)
  currency        String      @default("USD")
  shippingAddress Json
  paymentRef      String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  customer   User        @relation(fields: [customerId], references: [id])
  items      OrderItem[]
  shipments  Shipment[]

  @@index([customerId])
  @@index([status])
  @@index([paymentRef])
}

model OrderItem {
  id                     String  @id @default(uuid())
  orderId                String
  tenantId               String
  variantId              String
  qty                    Int
  unitPriceSnapshot      Decimal @db.Decimal(12, 2)
  commissionRateSnapshot Decimal @db.Decimal(5, 4)
  vendorPayoutAmount     Decimal @db.Decimal(12, 2)

  order   Order          @relation(fields: [orderId], references: [id])
  tenant  Tenant         @relation(fields: [tenantId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([tenantId])
  @@index([variantId])
}

model Shipment {
  id               String         @id @default(uuid())
  tenantId         String
  orderId          String
  carrier          String
  trackingNumber   String
  status           ShipmentStatus @default(CREATED)
  estimatedDelivery DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  order  Order  @relation(fields: [orderId], references: [id])

  @@index([tenantId])
  @@index([orderId])
  @@index([trackingNumber])
}

model Payout {
  id          String       @id @default(uuid())
  tenantId    String
  periodStart DateTime
  periodEnd   DateTime
  grossAmount Decimal      @db.Decimal(12, 2)
  platformFee Decimal      @db.Decimal(12, 2)
  netAmount   Decimal      @db.Decimal(12, 2)
  status      PayoutStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([status])
}

model Review {
  id         String   @id @default(uuid())
  productId  String
  customerId String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  product  Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer User    @relation(fields: [customerId], references: [id])

  @@unique([productId, customerId])
  @@index([productId])
  @@index([customerId])
}

model Follow {
  id        String   @id @default(uuid())
  userId    String
  tenantId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([userId])
  @@index([tenantId])
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String
  action     String
  targetType String
  targetId   String
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  actor User @relation("ActorLogs", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

// ─── Forum ────────────────────────────────────────────────────────────────────

model ForumSettings {
  id              String   @id @default(uuid())
  tenantId        String   @unique
  enabled         Boolean  @default(true)
  requireApproval Boolean  @default(false)
  allowGuestView  Boolean  @default(true)

  // ── Moderation (god-user / vendor configurable) ─────────────────────────────
  // OPEN: anyone allowed, no pre-mod; PRE_MODERATED: posts queued for approval;
  // LOCKED: no new posts/replies, read-only mode.
  moderationMode  ForumModerationMode  @default(OPEN)
  allowAnonymous  Boolean  @default(false)

  // ── Content rules ───────────────────────────────────────────────────────────
  minPostLength   Int      @default(1)
  maxPostLength   Int      @default(5000)
  allowImages     Boolean  @default(true)
  allowLinks      Boolean  @default(true)
  allowMentions   Boolean  @default(true)
  allowReactions  Boolean  @default(true)
  allowReplies    Boolean  @default(true)

  // ── Rate limiting ───────────────────────────────────────────────────────────
  slowModeSeconds Int      @default(0)  // 0 = disabled. Seconds between posts per user.

  // ── Access & posting policy ─────────────────────────────────────────────────
  visibility      ForumVisibility    @default(PUBLIC)
  postingPolicy   ForumPostingPolicy @default(EVERYONE)

  // ── Auto-moderation ─────────────────────────────────────────────────────────
  bannedKeywords  String[]            // case-insensitive substring match
  autoArchiveDays Int      @default(0) // 0 = never. Topics archived after N days of inactivity.

  // ── Community ───────────────────────────────────────────────────────────────
  welcomeMessage  String?  // shown to first-time visitors of the forum
  rulesText       String?  // markdown, shown on forum landing page

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

enum ForumModerationMode {
  OPEN
  PRE_MODERATED
  LOCKED
}

enum ForumVisibility {
  PUBLIC
  MEMBERS_ONLY
  FOLLOWERS_ONLY
}

enum ForumPostingPolicy {
  EVERYONE
  VERIFIED_ONLY
  FOLLOWERS_ONLY
}

model ForumChannel {
  id          String   @id @default(uuid())
  tenantId    String
  name        String   // e.g. "Genel", "Soru & Cevap", "Fanlar"
  slug        String   // e.g. "genel", "soru-cevap", "fanlar"
  description String?
  emoji       String   @default("💬")
  sortOrder   Int      @default(0)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  topics ForumTopic[]

  @@unique([tenantId, slug])
  @@index([tenantId, sortOrder])
}

model ForumTopic {
  id             String   @id @default(uuid())
  tenantId       String
  channelId      String?
  authorId       String
  title          String
  body           String
  imageUrl       String?
  pinned         Boolean  @default(false)
  locked         Boolean  @default(false)
  viewCount      Int      @default(0)
  hasArtistReply Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel   ForumChannel?  @relation(fields: [channelId], references: [id], onDelete: SetNull)
  author    User           @relation(fields: [authorId], references: [id])
  replies   ForumReply[]
  reactions ForumReaction[]

  @@index([tenantId, createdAt])
  @@index([tenantId, channelId, createdAt])
  @@index([authorId])
}

model ForumReply {
  id             String   @id @default(uuid())
  topicId        String
  authorId       String
  body           String
  imageUrl       String?
  parentReplyId  String?
  isArtistAnswer Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  topic         ForumTopic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  author        User          @relation(fields: [authorId], references: [id])
  parentReply   ForumReply?   @relation("ReplyThread", fields: [parentReplyId], references: [id], onDelete: SetNull)
  childReplies  ForumReply[]  @relation("ReplyThread")
  reactions     ForumReaction[]

  @@index([topicId, createdAt])
  @@index([authorId])
}

model ForumReaction {
  id        String        @id @default(uuid())
  userId    String
  emoji     ReactionEmoji
  topicId   String?
  replyId   String?
  createdAt DateTime      @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic ForumTopic? @relation(fields: [topicId], references: [id], onDelete: Cascade)
  reply ForumReply? @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@unique([userId, emoji, topicId])
  @@unique([userId, emoji, replyId])
  @@index([topicId])
  @@index([replyId])
}

// ─── Media Embeds ─────────────────────────────────────────────────────────────

model VendorMedia {
  id        String    @id @default(uuid())
  tenantId  String
  type      MediaType
  url       String
  title     String?
  sortOrder Int       @default(0)
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, sortOrder])
}

// ─── Events ───────────────────────────────────────────────────────────────────

model VendorEvent {
  id          String        @id @default(uuid())
  tenantId    String
  title       String
  description String?
  href        String
  provider    EventProvider @default(OTHER)
  date        DateTime
  venue       String?
  imageUrl    String?
  active      Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, date])
  @@index([date])
}

// ─── NFC Tags ─────────────────────────────────────────────────────────────────

model NfcTag {
  id             String    @id @default(uuid())
  name           String
  staticUrl      String    @unique
  destinationUrl String
  enabled        Boolean   @default(true)
  scanCount      Int       @default(0)
  lastScannedAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  tenantId       String?
  tenant         Tenant?   @relation(fields: [tenantId], references: [id])

  @@index([staticUrl])
  @@index([tenantId])
}

// ─── Platform Settings (singleton) ───────────────────────────────────────────

model PlatformSettings {
  id String @id @default("singleton")

  // ── Platform Identity ──────────────────────────────────────────────────────
  platformName        String  @default("VibeHub")
  platformTagline     String  @default("Your merch, your stage.")
  supportEmail        String  @default("support@vibehub.com.tr")
  supportPhone        String?
  logoUrl             String?
  faviconUrl          String?
  primaryColor        String  @default("#7C3AED")
  darkModeDefault     Boolean @default(false)

  // ── Commerce ───────────────────────────────────────────────────────────────
  defaultCommissionRate    Float   @default(15.0)
  currency                 String  @default("TRY")
  taxRate                  Float   @default(0.0)
  minProductPrice          Float   @default(0.0)
  maxProductPrice          Float?
  freeShippingThreshold    Float?
  allowGuestCheckout       Boolean @default(true)
  minPayoutAmount          Float   @default(50.0)
  payoutSchedule           String  @default("MANUAL")

  // ── Vendor Controls ────────────────────────────────────────────────────────
  vendorSignupsOpen        Boolean @default(true)
  autoApproveVendors       Boolean @default(false)
  maxProductsPerVendor     Int     @default(100)
  productSubmissionsOpen   Boolean @default(true)
  autoApproveProducts      Boolean @default(false)

  // ── Content & Reviews ──────────────────────────────────────────────────────
  globalForumEnabled       Boolean @default(true)
  requirePurchaseReview    Boolean @default(false)
  autoApproveReviews       Boolean @default(false)
  maxImagesPerProduct      Int     @default(10)
  maxReviewLength          Int     @default(2000)
  allowVideoUploads        Boolean @default(true)

  // ── Security ───────────────────────────────────────────────────────────────
  maxLoginAttempts         Int     @default(5)
  sessionDurationHours     Int     @default(24)
  requireEmailVerification Boolean @default(true)
  maintenanceMode          Boolean @default(false)
  maintenanceMessage       String  @default("We'll be back shortly. Thanks for your patience!")

  // ── Notifications ──────────────────────────────────────────────────────────
  orderNotificationEmail   String?
  lowStockThreshold        Int     @default(5)
  notifyVendorOnSale       Boolean @default(true)
  notifyAdminOnVendorApply Boolean @default(true)

  // ── SEO & Marketing ────────────────────────────────────────────────────────
  metaTitle                String  @default("VibeHub — Your Merch, Your Stage")
  metaDescription          String  @default("Buy official merch from your favourite artists and creators.")
  facebookPixelId          String?
  googleTagManagerId       String?

  updatedAt DateTime @updatedAt
}

// ── Mobile push devices ───────────────────────────────────────────────────────

enum DevicePlatform {
  IOS
  ANDROID
}

model PushDevice {
  id         String         @id @default(uuid())
  userId     String
  platform   DevicePlatform
  token      String         @unique
  appVersion String?
  lastUsed   DateTime       @default(now())
  createdAt  DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── Mobile app config ─────────────────────────────────────────────────────────

model AppConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// ── In-app notifications ──────────────────────────────────────────────────────

enum NotificationType {
  ORDER_SHIPPED
  FORUM_REPLY
  NEW_DROP
}

model AppNotification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
