# Application
NODE_ENV=development    # Set to 'production' in prod (disables Swagger, OTP debug logs)
PORT=3001

# Database
DATABASE_URL="postgresql://vibehub:vibehub_secret@localhost:5432/vibehub?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

# JWT
JWT_ACCESS_SECRET=change_me_access_secret_32chars_min
JWT_REFRESH_SECRET=change_me_refresh_secret_32chars_min
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# God User seed credentials (used only on first run)
GOD_USER_EMAIL=god@vibehub.com.tr
GOD_USER_PASSWORD=God@VibeHub2025!

# İyzico — get credentials from https://merchant.iyzipay.com
# Sandbox base URL: https://sandbox-api.iyzipay.com
# Production base URL: https://api.iyzipay.com
IYZICO_API_KEY=replace_with_your_iyzico_api_key
IYZICO_SECRET_KEY=replace_with_your_iyzico_secret_key
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
IYZICO_CALLBACK_URL=http://localhost:3001/payments/iyzico/callback

# File storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:3000

# CORS — comma-separated list of allowed Vercel preview project slugs (NOT wildcard)
# Example: ALLOWED_VERCEL_PREVIEWS=vibehub-frontend-emrexx,vibehub-staging-abc123
ALLOWED_VERCEL_PREVIEWS=

# CORS — additional allowed origins beyond FRONTEND_URL (comma-separated full URLs)
CORS_EXTRA_ORIGINS=
